{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "smoke-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_SHARED_LIBS": "ON",
        "ENABLE_COVERAGE": "OFF",
        "ENABLE_STRESS_TESTS": "OFF",
        "ENABLE_SANITIZERS": "OFF",
        "ENABLE_CLANG_TIDY": "OFF",
        "ENABLE_CPPCHECK": "OFF",
        "ENABLE_IWYU": "OFF",
        "ENABLE_STRICT_WARNINGS": "ON"
      }
    },
    {
      "name": "macos-smoke",
      "displayName": "macOS smoke",
      "inherits": "smoke-base"
    },
    {
      "name": "linux-smoke",
      "displayName": "Linux smoke",
      "inherits": "smoke-base"
    },
    {
      "name": "windows-smoke",
      "displayName": "Windows smoke",
      "inherits": "smoke-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "full-base",
      "hidden": true,
      "inherits": "smoke-base",
      "cacheVariables": {
        "ENABLE_STRICT_WARNINGS": "OFF"
      }
    },
    {
      "name": "macos-full",
      "displayName": "macOS full",
      "inherits": "full-base"
    },
    {
      "name": "linux-gcc-full",
      "displayName": "Linux GCC full",
      "inherits": "full-base"
    },
    {
      "name": "linux-clang-full",
      "displayName": "Linux Clang full",
      "inherits": "full-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-asan-ubsan",
      "displayName": "Linux ASan+UBSan",
      "inherits": "full-base",
      "cacheVariables": {
        "ENABLE_SANITIZERS": "ON",
        "SANITIZERS": "address;undefined"
      }
    },
    {
      "name": "windows-full",
      "displayName": "Windows full",
      "inherits": "full-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_SHARED_LIBS": "OFF"
      }
    }
  ],
